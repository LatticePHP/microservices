{
    "name": "lattice/microservices",
    "description": "Microservices messaging kernel for LatticePHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "microservices",
        "messaging",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/microservices"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Microservices\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Microservices\\Tests\\": "tests/"
        }
    }
}
